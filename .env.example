APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

# Databasen lagres i UTC; denne tidssonen brukes kun ved visning (f.eks. e-poster).
APP_DISPLAY_TIMEZONE=Europe/Oslo

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Prod bruker MySQL/MariaDB; lokalt kan du bruke sqlite (DB_CONNECTION=sqlite og fjern resten).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=finans_db
DB_USERNAME=finans_user
DB_PASSWORD=BYTT_MEG

SESSION_DRIVER=database
SESSION_LIFETIME=525600
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# App-passord (sett med: php artisan app:set-password)
APP_PASSWORD_HASH=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Lokalt: «log» skriver e-post til laravel.log i stedet for å sende.
# Prod (ProISP SMTP): sett MAIL_MAILER=smtp og fyll inn MAIL_PASSWORD.
# Port 465 krever MAIL_SCHEME=smtps (implisitt SSL/TLS); 587 ville vært STARTTLS.
MAIL_MAILER=log
MAIL_SCHEME=smtps
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=finans@holthe.org
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="finans@holthe.org"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# GoCardless (bankintegrasjon)
GOCARDLESS_BASE_URI=https://bankaccountdata.gocardless.com/api/v2
GOCARDLESS_REDIRECT_URI="${APP_URL}/api/bank/callback"
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=
GOCARDLESS_SANDBOX_BANK=SANDBOXFINANCE_SFIN0000
BANK_SYNC_REPORT_EMAIL=
BANK_CONSENT_EXPIRY_WARNING_DAYS=7

# Enable Banking (bankleverandør nr. 2 – gratis tier for personlig bruk)
# ENABLEBANKING_PRIVATE_KEY kan være PEM-innholdet (med \n) eller en filsti.
ENABLEBANKING_BASE_URI=https://api.enablebanking.com
ENABLEBANKING_APPLICATION_ID=
ENABLEBANKING_PRIVATE_KEY=
ENABLEBANKING_REDIRECT_URI="${APP_URL}/api/bank/callback"
ENABLEBANKING_COUNTRY=NO

# PSU-kontekst (Berlin Group/PSD2). Noen banker (f.eks. Bulder) krever
# psu-ip-address-headeren og avviser uovervåket synk uten den. Ved cron-synk
# finnes ingen bruker, så denne fallbacken brukes – sett den til serverens
# utgående offentlige IP i prod. La stå tom lokalt.
ENABLEBANKING_PSU_IP=
ENABLEBANKING_PSU_USER_AGENT=Finans/1.0
